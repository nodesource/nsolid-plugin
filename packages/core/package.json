{
  "name": "nsolid-plugin",
  "version": "1.0.0-next.0",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "bin": {
    "nsolid-plugin": "./dist/src/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./scripts/setup.mjs": "./scripts/setup.mjs"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc",
    "test": "node ../../scripts/run-tests.mjs core",
    "lint": "eslint src/ test/",
    "skills:sync": "node scripts/sync-shared-skill-assets.mjs",
    "skills:check": "node scripts/sync-shared-skill-assets.mjs --check",
    "bundle:sync": "node scripts/check-bundle-sync.mjs --sync",
    "bundle:check": "node scripts/check-bundle-sync.mjs --check",
    "prepublishOnly": "pnpm run build",
    "prepack": "pnpm run build && pnpm run skills:sync && pnpm run bundle:sync && node -e \"require('node:fs').chmodSync('dist/src/cli.js', 0o755)\""
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "dependencies": {
    "smol-toml": "^1.3.1",
    "write-file-atomic": "^5.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/write-file-atomic": "4.0.3",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22.3.0"
  },
  "files": [
    "dist/src/",
    "skills/",
    "bundle.json",
    "scripts/"
  ]
}