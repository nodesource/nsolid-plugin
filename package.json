{
  "name": "nsolid-plugin",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:unit": "vitest run packages/core/test/unit",
    "test:integration": "vitest run packages/core/test/integration",
    "lint": "pnpm -r lint",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.4.1",
    "husky": "9.1.7",
    "typescript-eslint": "8.61.0",
    "vitest": "4.1.8"
  }
}
